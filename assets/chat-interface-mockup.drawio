        </mxCell>
        <mxCell id="user-msg-container" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#334155;strokeColor=none;arcSize=8;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;spacingBottom=10;" value="" vertex="1">
