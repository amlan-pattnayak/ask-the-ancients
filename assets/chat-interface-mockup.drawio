        <mxCell id="user-msg-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=14;fontColor=#faf8f0;fontFamily=Inter;" value="How do I stop worrying about things I can&#39;t control?" vertex="1">
          <mxGeometry height="40" width="294" x="85" y="250" as="geometry" />
        </mxCell>
        <mxCell id="msg2-container" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e293b;strokeColor=#334155;arcSize=8;align=left;verticalAlign=top;spacingLeft=60;spacingTop=10;spacingRight=10;spacingBottom=10;" value="" vertex="1">
