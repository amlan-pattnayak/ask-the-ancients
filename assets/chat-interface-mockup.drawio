        <mxCell id="msg1-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=14;fontColor=#faf8f0;fontFamily=Crimson Pro;spacingTop=5;spacingLeft=0;" value="Welcome, friend. I am Marcus, once emperor of Rome, always a student of philosophy. What weighs on your mind today?" vertex="1">
