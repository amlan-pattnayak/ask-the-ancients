# Ask the Ancients - environment template
# Copy to .env.local for local development. Do not commit secrets.

# Public client config
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk auth
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# App URL (used for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_APP_URL=
GROQ_API_KEY=
OPENAI_API_KEY=

# Guest/shared inference controls
GUEST_MODE_ENABLED=
GUEST_PROVIDER=
GUEST_DAILY_LIMIT_ANON=
GUEST_DAILY_LIMIT_USER=
BURST_MIN_INTERVAL_MS=
BUDGET_ALERT_THRESHOLD=

# Optional helper for eval harness script
EVAL_ANON_ID=

# Required to cryptographically verify anon→user merge ownership.
MERGE_PROOF_SECRET=

# Optional deploy-time variable used by Convex tooling in some workflows
CONVEX_DEPLOY_KEY=

# Admin-only KPI dashboard access (/kpi)
# Comma-separated allowlists; access is granted if either user ID or email matches.
ADMIN_CLERK_USER_IDS=
ADMIN_EMAILS=
